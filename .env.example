# =============================================================================
# bruh. — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`. Values below are blank or examples only.
# =============================================================================

# -----------------------------------------------------------------------------
# App (required)
# -----------------------------------------------------------------------------
# Public base URL of the app. Used for OAuth redirects, emails, and metadata.
# Local dev: http://localhost:3000 — Production: https://getbruh.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase — Database + Auth (required)
# Find these in Supabase Dashboard → Project Settings → API.
# -----------------------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose in the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SECRET. Server-side only. Bypasses RLS. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Cron / Scheduled jobs (required in production)
# -----------------------------------------------------------------------------
# Shared secret to authorize cron endpoints (e.g. recurring tasks, digests).
# Vercel Cron sends this as a Bearer token. Generate a long random string.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Stripe — Billing (required for paid plans)
# Find keys in Stripe Dashboard → Developers → API keys.
# -----------------------------------------------------------------------------
# Secret API key — SECRET. Server-side only. e.g. sk_test_... / sk_live_...
STRIPE_SECRET_KEY=
# Price ID for the subscription plan. e.g. price_...
STRIPE_PRICE_ID=
# Webhook signing secret — SECRET. From the webhook endpoint config. e.g. whsec_...
STRIPE_WEBHOOK_SECRET=
# Publishable key (safe to expose in the browser). e.g. pk_test_... / pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend — Transactional email (required for emails/invites/digests)
# Find/create at https://resend.com → API Keys.
# -----------------------------------------------------------------------------
# API key — SECRET. e.g. re_...
RESEND_API_KEY=
# From address for outbound email. Must be a verified domain/sender.
# e.g. bruh. <hello@getbruh.app>
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Anthropic — AI Brain Dump (optional)
# The Brain Dump feature falls back to a local parser without this, but works
# much better with Claude. https://console.anthropic.com
# -----------------------------------------------------------------------------
# API key — SECRET. e.g. sk-ant-...
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Google — Calendar integration (optional)
# Create OAuth credentials in Google Cloud Console, enable Calendar API, and add
# ${NEXT_PUBLIC_APP_URL}/api/integrations/google/callback as a redirect URI.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
# SECRET.
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Notion — integration (optional)
# Create an OAuth integration at https://www.notion.so/my-integrations
# -----------------------------------------------------------------------------
NOTION_CLIENT_ID=
# SECRET.
NOTION_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Slack — integration (optional)
# Create an app at https://api.slack.com/apps
# -----------------------------------------------------------------------------
SLACK_CLIENT_ID=
# SECRET.
SLACK_CLIENT_SECRET=
# SECRET. Used to verify inbound Slack request signatures.
SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Inbound email (optional)
# Shared secret to verify inbound email webhooks (task-by-email).
# -----------------------------------------------------------------------------
INBOUND_EMAIL_SECRET=

# -----------------------------------------------------------------------------
# Upstash Redis — Rate limiting (optional but recommended in production)
# Create a database at https://console.upstash.com → REST API.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
# SECRET.
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Sentry — error tracking (optional). Public DSN is safe to expose.
# SENTRY_AUTH_TOKEN is build-time only (source-map upload) — SECRET.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# SECRET (build-time source maps).
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Google Calendar push webhook verification token (optional).
# -----------------------------------------------------------------------------
GOOGLE_WEBHOOK_TOKEN=
